# Local server port
PORT=8000

# GitHub auto-commit target
GITHUB_OWNER=gusdnr0226
GITHUB_REPO=portfolio
GITHUB_BRANCH=main
GITHUB_PORTFOLIO_PATH=data/portfolios.json

# Required: fine-grained token with Contents: Read and write
GITHUB_TOKEN=ghp_your_token_here

# Optional commit metadata
GITHUB_COMMITTER_NAME=portfolio-sync-bot
GITHUB_COMMITTER_EMAIL=portfolio-sync-bot@users.noreply.github.com

# Set to false if you only want manual GitHub commit from the UI button
AUTO_COMMIT_ON_UPLOAD=true
